<view xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://schema.qcadoo.org/view"
      xsi:schemaLocation="http://schema.qcadoo.org/view http://schema.qcadoo.org/view.xsd"
      name="palletLoadUnitsTransferHelper" modelName="document" modelPlugin="materialFlowResources">

    <component type="window" name="window" reference="window">

        <ribbon>
            <group name="navigation">
                <bigButton name="back" icon="backIcon24.png" state="enabled" action="#{window}.performBackWithoutConfirm"/>
            </group>
            <group name="action">
                <bigButton name="transferLoadUnits" icon="saveIcon24.png" state="enabled">
                    <script>
                        <![CDATA[
							this.addOnChangeListener({
								onClick: function() {
										#{form}.performEvent('transferLoadUnits', []);
								}
							});
						]]>
                    </script>
                </bigButton>
            </group>
        </ribbon>


        <windowTab name="mainTab">
            <component type="form" name="form" reference="form">

                <component type="gridLayout" name="gridLayout" columns="3"
                           rows="1" hasBorders="false">
                    <layoutElement column="1" row="1">
                        <component type="lookup" name="locationTo" field="locationTo"
                                   reference="locationTo">
                            <option type="column" name="name" fields="name"/>

                            <option type="searchable" value="number,name"/>
                            <option type="orderable" value="number,name"/>

                            <option type="expression" value="#number + ' - ' + #name"/>
                            <option type="fieldCode" value="number"/>

                            <criteriaModifier
                                    class="com.qcadoo.mes.materialFlowResources.criteriaModifiers.LocationCriteriaModifiersMFR"
                                    method="showWarehousesOnly"/>
                        </component>

                        <component type="input" name="selectedEntities" reference="selectedEntities"
                                   defaultVisible="false" defaultEnabled="false"/>
                    </layoutElement>

                </component>

                <listener event="transferLoadUnits"
                          class="com.qcadoo.mes.materialFlowResources.listeners.PalletLoadUnitsTransferHelperListeners"
                          method="transferLoadUnits"/>
                <option type="header" value="true"/>
            </component>
        </windowTab>

    </component>

    <hooks>
    </hooks>
</view>