<windowTabExtension xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                    xmlns="http://schema.qcadoo.org/modules/windowTabExtension"
                    xsi:schemaLocation="http://schema.qcadoo.org/modules/windowTabExtension http://schema.qcadoo.org/modules/windowTabExtension.xsd"
                    plugin="deliveries" view="supplyParameters">

    <windowTab name="materialRequirementsTab" reference="materialRequirementsTab">
        <component type="gridLayout" name="materialRequirementsParametersGridLayout"
                   columns="3" rows="5">
            <layoutElement column="1" row="1">
                <component type="select" name="mrpAlgorithm"
                           field="#{form}.mrpAlgorithm" reference="mrpAlgorithm" />
            </layoutElement>
            <layoutElement column="1" row="2">
                <component type="checkbox" name="mrIncludeWarehouse" hasDescription="true"
                           field="#{form}.mrIncludeWarehouse" reference="mrIncludeWarehouse"/>
            </layoutElement>
            <layoutElement column="1" row="3">
                <component type="checkbox" name="mrShowCurrentStockLevel" hasDescription="true"
                           field="#{form}.mrShowCurrentStockLevel" reference="mrShowCurrentStockLevel"/>
            </layoutElement>
            <layoutElement column="1" row="4">
                <component type="checkbox" name="mrIncludeStartDateOrder" hasDescription="true"
                           field="#{form}.mrIncludeStartDateOrder" reference="mrIncludeStartDateOrder"/>
            </layoutElement>
            <layoutElement column="1" row="5">
                <component type="checkbox" name="mrShowReplacements" hasDescription="true"
                           field="#{form}.mrShowReplacements" reference="mrShowReplacements"/>
            </layoutElement>
        </component>
    </windowTab>

</windowTabExtension>